# =============================================================================
# FocusBlocks — API server configuration
# -----------------------------------------------------------------------------
# Create your local file from this template:
#   Windows (PowerShell):  Copy-Item .env.example .env
#   macOS / Linux:         cp .env.example .env
# Then edit .env if needed. Do not commit .env (it is listed in .gitignore).
# =============================================================================

# Port the Express API listens on. The Vite dev proxy must target this port
# (see client/.env.example → VITE_DEV_API_ORIGIN).
PORT=5175

# Secret used to sign JWT access tokens (minimum 16 characters for local dev).
# For NODE_ENV=production the server requires at least 32 characters.
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=local-development-only-use-openssl-rand-hex-32-in-production

# SQLite database file. Relative paths are resolved from the server/ folder.
# Parent directories are created automatically when the server starts.
DB_PATH=./data.db

# Browser origin allowed to call the API (CORS). Use the URL shown when you
# run `npm run dev` in the client (typically http://localhost:5173).
# Multiple origins: comma-separated, no spaces (or trim handled in code).
CLIENT_ORIGIN=http://localhost:5173

# Uncomment when deploying to a real host (required: set JWT_SECRET yourself).
# NODE_ENV=production
