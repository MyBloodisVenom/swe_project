# =============================================================================
# Time-Block Calendar — Vite (client) development configuration
# -----------------------------------------------------------------------------
# Optional: copy to .env if you change API port or run the client on another machine.
#   Windows (PowerShell):  Copy-Item .env.example .env
# =============================================================================

# Where Vite should proxy /api requests during `npm run dev`.
# Must match server PORT in server/.env (default 5175).
VITE_DEV_API_ORIGIN=http://localhost:5175
